{
  "name": "@tofrankie/clean",
  "type": "module",
  "version": "0.0.2",
  "packageManager": "pnpm@10.32.0",
  "description": "Clean node_modules, dist and tool cache files",
  "author": "Frankie <1426203851@qq.com> (https://github.com/tofrankie)",
  "license": "MIT",
  "homepage": "https://github.com/tofrankie/clean#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/clean.git"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/clean/issues"
  },
  "keywords": [
    "clean",
    "node_modules",
    "dist",
    "cache",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "clean": "./dist/cli.mjs",
    "clean-modules": "./bin/clean-modules.mjs",
    "clean-dist": "./bin/clean-dist.mjs",
    "clean-cache": "./bin/clean-cache.mjs",
    "clean-all": "./bin/clean-all.mjs"
  },
  "files": [
    "CHANGELOG.md",
    "bin",
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "prepublishOnly": "pnpm build",
    "lint": "run-s lint:eslint lint:prettier typecheck",
    "lint:eslint": "eslint . --cache --fix",
    "lint:prettier": "prettier . --cache --write --log-level silent '!pnpm-lock.yaml'",
    "typecheck": "tsc --noEmit",
    "publint": "publint",
    "publish:dry-run": "pnpm publish --dry-run",
    "test": "run-s test:unit test:smoke",
    "test:unit": "vitest run",
    "test:smoke": "node tests/smoke.test.js",
    "clean:all": "node dist/cli.mjs --all",
    "clean:modules": "node dist/cli.mjs modules",
    "clean:dist": "node dist/cli.mjs dist",
    "clean:cache": "node dist/cli.mjs cache",
    "github:release": "tfr"
  },
  "dependencies": {
    "@pnpm/find-workspace-dir": "^1000.1.5",
    "commander": "^14.0.3",
    "deepmerge": "^4.3.1",
    "fast-glob": "^3.3.3",
    "find-up": "^8.0.0",
    "jiti": "^2.6.1",
    "rimraf": "^6.1.3"
  },
  "devDependencies": {
    "@tofrankie/action": "^0.0.4",
    "@tofrankie/eslint": "^0.0.16",
    "@tofrankie/prettier": "^0.0.8",
    "@types/node": "^25.5.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "publint": "^0.3.12",
    "tsdown": "^0.21.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
